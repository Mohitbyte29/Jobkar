generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id           Int           @id @default(autoincrement())
  name         String        @db.VarChar(255)
  email        String        @unique @db.VarChar(255)
  password     String?        @db.VarChar(255)
  role         Role          @default(SEEKER)
  isOnboarded   Boolean       @default(false)
  isLoggedIn    Boolean       @default(false) 
  isVerified    Boolean       @default(false)
  avatar       String?       @db.VarChar(255)
  resume       String?       @db.VarChar(255)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  applications Application[]
  companies    Company[]
  employers    Employer?

  @@map("users")
}

model Employer {
  id         Int          @id @default(autoincrement())
  userId     Int          @unique
  companyId  Int?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  company    Company?      @relation(fields: [companyId], references: [id])
  user       User         @relation(fields: [userId], references: [id])
  internship Internship[]
  jobs       Job[]

  @@index([companyId], map: "employers_companyId_fkey")
  @@map("employers")
}

model Company {
  id            Int           @id @default(autoincrement())
  name          String        @db.VarChar(255)
  logo          String?
  description   String        @db.Text
  website       String        @db.VarChar(255)
  location      String        @db.VarChar(255)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  companyStatus companyStatus @default(ACTIVE)
  UserId        Int
  category      String       @db.VarChar(255)
  user          User          @relation(fields: [UserId], references: [id])
  employers     Employer[]
  internship    Internship[]
  jobs          Job[]

  @@index([UserId], map: "companies_UserId_fkey")
  @@map("companies")
}

model Job {
  id           Int           @id @default(autoincrement())
  title        String        @db.VarChar(255)
  description  String        @db.Text
  category     String        @db.VarChar(255)
  requirements String        @db.Text
  location     String        @db.VarChar(255)
  tags         Json
  salaryMin    Int?
  salaryMax    Int?
  remote       Boolean       @default(false)
  type         JobType
  status       JobStatus     @default(ACTIVE)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  CompanyId    Int
  employerId   Int
  applications Application[]
  company      Company       @relation(fields: [CompanyId], references: [id])
  employer     Employer      @relation(fields: [employerId], references: [userId])

  @@index([CompanyId], map: "jobs_CompanyId_fkey")
  @@index([employerId], map: "jobs_employerId_fkey")
  @@map("jobs")
}

model Application {
  id           Int                @id @default(autoincrement())
  userId       Int
  jobId        Int
  resume       String?
  coverletter  String
  status       APPLICATION_STATUS @default(PENDING)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  internshipId Int
  internship   Internship         @relation(fields: [internshipId], references: [id])
  job          Job                @relation(fields: [jobId], references: [id])
  user         User               @relation(fields: [userId], references: [id])

  @@index([internshipId], map: "applications_internshipId_fkey")
  @@index([jobId], map: "applications_jobId_fkey")
  @@index([userId], map: "applications_userId_fkey")
  @@map("applications")
}

model Internship {
  id               Int                         @id @default(autoincrement())
  title            String                      @db.VarChar(255)
  description      String                      @db.Text
  category         String                     @db.VarChar(255)
  requirements     String                      @db.Text
  location         String                      @db.VarChar(255)
  tags             Json
  salaryMin        Int?
  salaryMax        Int?
  remote           Boolean                     @default(false)
  type             internship_type
  createdAt        DateTime                    @default(now())
  updatedAt        DateTime
  CompanyId        Int
  employerId       Int
  workType         internship_workType
  internshipStatus internshipStatus @default(ACTIVE)
  applications     Application[]
  companies        Company                     @relation(fields: [CompanyId], references: [id], map: "Internship_CompanyId_fkey")
  employers        Employer                    @relation(fields: [employerId], references: [userId], map: "Internship_employerId_fkey")

  @@index([CompanyId], map: "Internship_CompanyId_fkey")
  @@index([employerId], map: "Internship_employerId_fkey")
}

enum JobType {
  FULL_TIME
  PART_TIME
  CONTRACT
  REMOTE
  INTERN
}

enum Role {
  SEEKER
  EMPLOYER
  ADMIN
}

enum JobStatus {
  ACTIVE
  DRAFT
  CLOSED
}

enum APPLICATION_STATUS {
  PENDING
  ACCEPTED
  REJECTED
}

enum companyStatus {
  ACTIVE
  INACTIVE
}

enum internship_type {
  Paid
  Unpaid
}

enum internship_workType {
  REMOTE
  ONSITE
  HYBRID
}

enum internshipStatus {
  ACTIVE
  DRAFT
  CLOSED
}

enum category {
  TECHNOLOGY_SOFTWARE
  CREATIVE_MEDIA
  MARKETING
  HEALTHCARE
  FINANCE
  EDUCATION_GOVERNMENT
  BUSINESS_OPERATIONS
  OTHER
}
