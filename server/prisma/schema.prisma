// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(255)
  email     String   @unique @db.VarChar(255)
  password  String   @db.VarChar(255)
  role Role @default(SEEKER)
  avatar String? @db.VarChar(255)
  resume String? @db.VarChar(255)
  createdAt DateTime @default(now())
  updatedAt DateTime  @updatedAt

  jobs Job[]
  companies Company[]
  internships Internship[]
  @@map("users")
  applications Application[]
}

model Company{
  id Int @id @default(autoincrement())
  name String @db.VarChar(255)
  logo String?
  description String @db.Text
  website String @db.VarChar(255)
  location String @db.VarChar(255)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  companyStatus companyStatus @default(ACTIVE)

  jobs Job[]
  internships Internship[]
  UserId Int
  user User @relation(fields: [UserId], references: [id])
  
  @@map("companies")
}

model Job {
  id Int @id @default(autoincrement())
  title String @db.VarChar(255)
  description String @db.Text
  category String @db.VarChar(255)
  requirements String @db.Text
  location String @db.VarChar(255)
  tags Json
  salaryMin Int?
  salaryMax Int?
  remote Boolean @default(false)
  type JobType 
  status JobStatus @default(ACTIVE)
  createdAt DateTime @default(now()) 
  updatedAt DateTime @updatedAt
  CompanyId Int
  company Company @relation(fields: [CompanyId], references: [id])
  employerId Int
  employer User @relation(fields: [employerId], references: [id])
  applications Application[]

  @@map("jobs")
}

model Internship {
  id Int @id @default(autoincrement())
  title String @db.VarChar(255)
  description String @db.Text
  category String @db.VarChar(255)
  requirements String @db.Text
  location String @db.VarChar(255)
  tags Json
  salaryMin Int?
  salaryMax Int?
  remote Boolean @default(false)
  type InternshipType 
  workType InternshipWorkType
  internshipStatus InternshipStatus @default(ACTIVE)
  createdAt DateTime @default(now()) 
  updatedAt DateTime @updatedAt
  CompanyId Int
  company Company @relation(fields: [CompanyId], references: [id])
  employerId Int
  employer User @relation(fields: [employerId], references: [id])
  applications Application[]

  @@map("Internship")
}

model Application {
  id Int @id @default(autoincrement())
  userId Int
  jobId Int
  internshipId Int
  resume String?
  coverletter String
  status APPLICATION_STATUS @default(PENDING)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  user User @relation(fields: [userId], references: [id])
  job Job @relation(fields: [jobId], references: [id])
  internship Internship @relation(fields: [internshipId], references: [id])

  @@map("applications")
}

enum JobType {
  FULL_TIME
  PART_TIME
  CONTRACT
  REMOTE
  INTERN
}

enum Role {
  SEEKER
  EMPLOYER
  ADMIN
}

enum JobStatus {
  ACTIVE
  DRAFT
  CLOSED
}

enum APPLICATION_STATUS {
  PENDING
  ACCEPTED
  REJECTED
}

enum companyStatus {
  ACTIVE
  INACTIVE
}

enum category {
  TECHNOLOGY_SOFTWARE
  CREATIVE_MEDIA
  MARKETING
  HEALTHCARE
  FINANCE
  EDUCATION_GOVERNMENT
  BUSINESS_OPERATIONS
  OTHER
}

enum InternshipType {
  Paid
  Unpaid
}

enum InternshipStatus {
  ACTIVE
  DRAFT
  CLOSED
}

enum InternshipWorkType {
  REMOTE
  ONSITE
  HYBRID
}
